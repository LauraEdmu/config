{
  "editor.fontFamily": "Jetbrains Mono",
  "explorer.confirmPasteNative": false,
  "security.workspace.trust.untrustedFiles": "open",
  "explorer.confirmDragAndDrop": false,
  "github.copilot.nextEditSuggestions.enabled": true,
  "python.defaultInterpreterPath": "C:\\Users\\laura\\AppData\\Local\\Programs\\Python\\Python314\\python.exe",
  "vim.smartRelativeLine": true,
  "containers.containerClient": "com.microsoft.visualstudio.containers.docker",
  "containers.orchestratorClient": "com.microsoft.visualstudio.orchestrators.dockercompose",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.diagnosticSeverityOverrides": {
    "reportUnusedVariable": "warning",
    "reportUnusedImport": "warning"
  },
  "chat.editor.fontFamily": "Jetbrains Mono",
  "editor.fontLigatures": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  }
}